{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "hostRules": [
    {
      "hostType": "docker",
      "abortOnError": false
    }
  ],
  "labels": ["dependencies"],
  "dependencyDashboard": true,
  "argocd": {
    "managerFilePatterns": [
      "/argo-cd/.+\\.yaml$/"
    ]
  },
  "helm-values": {
    "enabled": false
  },
  "extends": [
    "config:recommended",
    ":timezone(Asia/Tokyo)",
    ":prHourlyLimitNone",
    ":automergePatch"
  ],
  "automerge": true,
  "ignorePaths": [
    "argo-cd/base"
  ],
  "packageRules": [
    {
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "automerge": true
    }
  ]
}
